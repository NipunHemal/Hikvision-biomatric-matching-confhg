# --- Webhook receiver (this backend) ---
PORT=8080
# IP of THIS machine as reachable from the device's network (not 127.0.0.1)
LISTENER_HOST=192.168.1.50
WEBHOOK_PATH=/hik/event

# Optional HTTP Basic auth that the device will use when posting events.
# Leave blank to disable (device httpAuthenticationMethod=none).
WEBHOOK_USER=
WEBHOOK_PASS=

# Save face/scene snapshots that come with events
SAVE_PICTURES=true

# Log every inbound request in full (headers + body) and expose the last 20
# at GET /debug/requests. Turn on while wiring up a device, off in production.
DEBUG_REQUESTS=true

# Punches made while this server was unreachable exist only on the terminal.
# Auto-sync pulls them from the device's own log.
BACKFILL_ON_START=true
BACKFILL_INTERVAL_MIN=15
# Re-scan this far back each sweep so a punch in the same second as the last
# sync is not stepped over. Duplicates are ignored, so overlap is free.
BACKFILL_OVERLAP_MIN=60

# --- Hikvision device (DS-K1T808MFWX-B) ---
DEVICE_HOST=192.168.1.64
DEVICE_PORT=80
DEVICE_USER=admin
DEVICE_PASS=changeme
