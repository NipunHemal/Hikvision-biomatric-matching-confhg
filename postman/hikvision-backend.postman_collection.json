{
  "info": {
    "name": "Hikvision DS-K1T808MFWX-B Backend",
    "description": "Local backend for the DS-K1T808MFWX-B access terminal.\n\nSelect the 'Hik backend - local' environment before running.\n\nMost requests carry test assertions, so the whole collection can be run in Collection Runner or with newman.\n\nRequests marked [WRITES TO DEVICE] change state on the real terminal. Requests marked [DESTRUCTIVE] remove data. Read the folder descriptions before running either against production hardware.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "employeeNo",
      "value": "1042",
      "type": "string"
    },
    {
      "key": "webhookUser",
      "value": "",
      "type": "string"
    },
    {
      "key": "webhookPass",
      "value": "",
      "type": "string"
    },
    {
      "key": "deviceIp",
      "value": "10.222.109.123",
      "type": "string"
    },
    {
      "key": "eventId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "doorNo",
      "value": "1",
      "type": "string"
    },
    {
      "key": "fingerPrintID",
      "value": "1",
      "type": "string"
    },
    {
      "key": "simUrl",
      "value": "http://127.0.0.1:8100",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & debug",
      "description": "Liveness and request inspection. /debug/requests needs DEBUG_REQUESTS=true in .env.",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Answers any HTTP method."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('reports uptime', () => pm.expect(pm.response.json()).to.have.property('uptime'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Recent raw requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/debug/requests",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "debug",
                "requests"
              ]
            },
            "description": "Last 20 inbound requests with full headers and bodies, newest first. Needs DEBUG_REQUESTS=true. Logs the Authorization header, so keep it off in production."
          }
        }
      ]
    },
    {
      "name": "Webhook (simulate the device)",
      "description": "These imitate what the terminal POSTs, so you can exercise the backend without touching hardware. Basic auth is applied because WEBHOOK_USER is set in .env; clear those vars if you disabled it.",
      "item": [
        {
          "name": "Fingerprint punch (JSON)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{webhookUser}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{webhookPass}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ipAddress\": \"{{deviceIp}}\",\n  \"eventType\": \"AccessControllerEvent\",\n  \"dateTime\": \"2026-07-19T09:00:00+05:30\",\n  \"AccessControllerEvent\": {\n    \"majorEventType\": 5,\n    \"subEventType\": 113,\n    \"employeeNoString\": \"{{employeeNo}}\",\n    \"name\": \"Supun\",\n    \"currentVerifyMode\": \"fingerprintOrCard\",\n    \"attendanceStatus\": \"checkIn\",\n    \"serialNo\": 1001,\n    \"doorNo\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/hik/event",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hik",
                "event"
              ]
            },
            "description": "subEventType 113 = fingerprint auth success. The minor code — not currentVerifyMode — determines verify_method."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('acked 200', () => pm.response.to.have.status(200));",
                  "// The webhook acks before storing, so give the write a moment, then confirm.",
                  "setTimeout(() => {",
                  "  pm.sendRequest(`${pm.variables.get('baseUrl')}/events?limit=1`, (err, res) => {",
                  "    if (err) return;",
                  "    const top = res.json()[0] || {};",
                  "    pm.test('stored as a fingerprint punch', () => {",
                  "      pm.expect(top.verify_method).to.eql('fingerprint');",
                  "      pm.expect(top.event_name).to.eql('fingerprintAuthSuccess');",
                  "    });",
                  "  });",
                  "}, 300);"
                ]
              }
            }
          ]
        },
        {
          "name": "Card punch (JSON)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
