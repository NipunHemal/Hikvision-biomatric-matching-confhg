    {
      "name": "Persons",
      "description": "[WRITES TO DEVICE] except the list request. These change real records on the terminal.",
      "item": [
        {
          "name": "List persons",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/persons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons"
              ]
            },
            "description": "Auto-paginated. Each person carries numOfFP / numOfCard / numOfFace showing what is enrolled."
          },
          "event": [
            {
              "listen": "test",
