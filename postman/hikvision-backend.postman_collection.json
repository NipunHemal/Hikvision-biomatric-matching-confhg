              "mode": "formdata",
              "formdata": [
                {
                  "key": "event_log",
                  "value": "{\"ipAddress\":\"{{deviceIp}}\",\"eventType\":\"AccessControllerEvent\",\"dateTime\":\"2026-07-19T09:03:00+05:30\",\"AccessControllerEvent\":{\"majorEventType\":5,\"subEventType\":75,\"employeeNoString\":\"{{employeeNo}}\",\"name\":\"Supun\",\"serialNo\":1004}}",
                  "type": "text"
                },
                {
                  "key": "Picture",
                  "type": "file",
                  "src": [],
                  "description": "Attach any JPEG"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/hik/event",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hik",
                "event"
              ]
            },
            "description": "What the device sends when picture upload is enabled: a JSON part named event_log plus a JPEG part. Pick a file for 'Picture' before sending."
          }
        },
        {
          "name": "Heartbeat (should be ignored)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{webhookUser}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{webhookPass}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ipAddress\": \"{{deviceIp}}\",\n  \"eventType\": \"AccessControllerEvent\",\n  \"dateTime\": \"2026-07-19T09:04:00+05:30\",\n  \"AccessControllerEvent\": {\n    \"majorEventType\": 5,\n    \"subEventType\": 0,\n    \"serialNo\": 1005\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/hik/event",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hik",
                "event"
              ]
            },
            "description": "Keep-alive with no credential attached. Acked with 200 but not stored — check GET /events to confirm it did not appear."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('acked 200', () => pm.response.to.have.status(200));",
                  "// A heartbeat must never become a stored punch.",
                  "setTimeout(() => {",
                  "  pm.sendRequest(`${pm.variables.get('baseUrl')}/events?limit=1`, (err, res) => {",
                  "    if (err) return;",
                  "    const top = res.json()[0] || {};",
                  "    pm.test('not stored as a punch', () => pm.expect(top.serial_no).to.not.eql(1005));",
                  "  });",
                  "}, 300);"
                ]
              }
            }
          ]
        },
        {
          "name": "Punch as XML (device may send this)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{webhookUser}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{webhookPass}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<EventNotificationAlert version=\"2.0\" xmlns=\"http://www.isapi.org/ver20/XMLSchema\">\n  <ipAddress>{{deviceIp}}</ipAddress>\n  <eventType>AccessControllerEvent</eventType>\n  <dateTime>2026-07-19T09:05:00+05:30</dateTime>\n  <AccessControllerEvent>\n    <majorEventType>5</majorEventType>\n    <subEventType>38</subEventType>\n    <employeeNoString>2077</employeeNoString>\n    <name>Nimal</name>\n    <cardNo>0012345678</cardNo>\n    <serialNo>1006</serialNo>\n  </AccessControllerEvent>\n</EventNotificationAlert>"
            },
            "url": {
              "raw": "{{baseUrl}}/hik/event",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hik",
                "event"
              ]
            },
            "description": "Firmware V3.25.x reports parameterFormatType as blank and may push XML rather than JSON. The webhook accepts both — this request proves the XML path works."
          },
          "event": [
