        {
          "name": "Punch with snapshot (multipart)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{webhookUser}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{webhookPass}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
