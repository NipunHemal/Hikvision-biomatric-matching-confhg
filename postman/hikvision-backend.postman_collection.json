                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns an array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create or update person [WRITES TO DEVICE]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeNo\": \"{{employeeNo}}\",\n  \"name\": \"Supun\",\n  \"userType\": \"normal\",\n  \"doorNo\": 1,\n  \"beginTime\": \"2026-01-01T00:00:00\",\n  \"endTime\": \"2030-12-31T23:59:59\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/persons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons"
              ]
            },
            "description": "Creates, or updates in place if employeeNo already exists. employeeNo is your join key to your own user table — set it deliberately."
          }
        },
        {
          "name": "Assign card [WRITES TO DEVICE]",
          "request": {
            "method": "POST",
            "header": [
