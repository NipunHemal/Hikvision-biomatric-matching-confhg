              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ipAddress\": \"{{deviceIp}}\",\n  \"eventType\": \"AccessControllerEvent\",\n  \"dateTime\": \"2026-07-19T09:02:00+05:30\",\n  \"AccessControllerEvent\": {\n    \"majorEventType\": 5,\n    \"subEventType\": 76,\n    \"employeeNoString\": \"3001\",\n    \"name\": \"Kamal\",\n    \"serialNo\": 1003\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/hik/event",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hik",
                "event"
              ]
            },
            "description": "subEventType 76 = face auth fail. Stored with success = 0."
          },
          "event": [
            {
              "listen": "test",
