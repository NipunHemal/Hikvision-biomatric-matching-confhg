              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons",
                "{{employeeNo}}",
                "card"
              ]
            }
          }
        },
        {
          "name": "Enrol face [WRITES TO DEVICE]",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "face",
