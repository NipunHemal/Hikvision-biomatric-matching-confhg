    {
      "name": "Simulator (no hardware needed)",
      "description": "Drives the simulated terminal from simulator/device.js — see SIMULATOR.md.\n\nStart it with `npm run simulator`, then point the backend at it:\n  DEVICE_HOST=127.0.0.1 DEVICE_PORT=8100 DEVICE_USER=admin DEVICE_PASS=simulator123 npm start\n\n{{simUrl}} defaults to http://127.0.0.1:8100. For a fleet (`npm run fleet`), change it per door: 8100, 8101, 8102...\n\nThese hit the SIMULATOR, not the backend — everything else in this collection hits the backend.",
      "item": [
        {
          "name": "Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{simUrl}}/sim/status",
              "host": [
                "{{simUrl}}"
              ],
              "path": [
                "sim",
                "status"
              ]
            },
            "description": "Persons, fingerprints, events held in the device log, registered webhook, push counters."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "console.log(`online=${d.online} persons=${d.persons} deviceLog=${d.eventsStored} pushed=${d.pushed} failures=${d.pushFailures}`);"
                ]
              }
            }
          ]
        },
        {
          "name": "Punch - fingerprint",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{simUrl}}/sim/punch",
              "host": [
                "{{simUrl}}"
              ],
              "path": [
                "sim",
                "punch"
              ]
            },
            "description": "Triggers a fingerprint punch (minor 113). The simulator records it to its own log and pushes it to the registered webhook.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeNo\": \"{{employeeNo}}\",\n  \"method\": \"fingerprint\",\n  \"doorNo\": 1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "pm.test('pushed to the backend', () => pm.expect(d.push.pushed).to.be.true);",
                  "console.log(`serial=${d.event.serialNo} minor=${d.event.minor}`);"
                ]
              }
            }
          ]
        },
        {
          "name": "Punch - card",
