                "raw"
              ]
            },
            "description": "The exact JSON the device sent for that event."
          }
        },
        {
          "name": "Purge local events - DRY RUN",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events?before=2026-06-01",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ],
              "query": [
                {
                  "key": "before",
                  "value": "2026-06-01"
                },
                {
                  "key": "source",
                  "value": "backfill",
                  "disabled": true
                }
              ]
            },
            "description": "Previews what a purge would remove — matched count, oldest/newest, pictures affected. Deletes NOTHING without &confirm=true.\n\nLOCAL ONLY: the terminal's own event log is never touched, so anything purged here can be recovered with POST /events/backfill."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "pm.test('is a dry run', () => pm.expect(d.dryRun).to.be.true);",
                  "pm.test('device log untouched', () => pm.expect(d.deviceLogUntouched).to.be.true);",
                  "console.log(`would delete ${d.matched} event(s), ${d.picturesAffected} picture(s)`);"
                ]
              }
            }
          ]
        },
        {
          "name": "Purge local events - CONFIRM [DESTRUCTIVE]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events?before=2026-06-01&confirm=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ],
              "query": [
                {
                  "key": "before",
                  "value": "2026-06-01"
                },
                {
                  "key": "confirm",
                  "value": "true"
                },
                {
                  "key": "source",
                  "value": "backfill",
                  "disabled": true
                },
                {
                  "key": "all",
                  "value": "true",
                  "disabled": true
                }
              ]
            },
            "description": "Deletes the matched rows and their snapshot files. Run the DRY RUN first and read the counts.\n\nA filter is required — ?before= and/or ?source=. Enable ?all=true only if you genuinely mean every row.\n\nThese are attendance records; the device log corroborates them, so prefer purging by date rather than wiping everything."
          }
        },
        {
          "name": "Backfill from device log",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/backfill",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "backfill"
              ],
              "query": [
                {
                  "key": "start",
                  "value": "2026-07-01T00:00:00",
                  "disabled": true
                },
                {
                  "key": "end",
                  "value": "2026-07-19T23:59:59",
                  "disabled": true
                }
              ]
            },
            "description": "Reads the terminal's own event log to recover punches missed during downtime. Read-only on the device; writes only to the local DB. Duplicates are ignored, so re-running is safe.\n\nThis also runs AUTOMATICALLY — on server startup, every BACKFILL_INTERVAL_MIN minutes (default 15), and the moment a device that had gone quiet starts POSTing again. Use this request to force a sweep now, or to backfill a specific historical window with ?start= and ?end=.\n\nWithout parameters it resumes from the newest stored event, rewound by BACKFILL_OVERLAP_MIN (default 60) so a punch in the same second as the last sync is not skipped."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "console.log(`scanned ${d.scanned}, inserted ${d.inserted}, skipped ${d.skipped}`);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Device",
      "description": "Read-only queries against the terminal.",
      "item": [
        {
          "name": "Device health (online / offline)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/device/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "device",
                "health"
              ]
            },
            "description": "Returns 200 when healthy, 503 when not — usable directly as a monitoring probe.\n\nChecks both directions:\n- device.reachable — can this server reach the terminal (ISAPI probe + latency)\n- webhook.receiving — has the terminal POSTed recently (it sends a keep-alive about every 30s; stale after 90s)\n\nBoth must be true for healthy. reachable=true with receiving=false means the terminal is up but cannot deliver events — check the inbound firewall rule, LISTENER_HOST, and that the auth setting matches on both sides."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('answers 200 (healthy) or 503 (not)', () => pm.expect([200,503]).to.include(pm.response.code));",
                  "const d = pm.response.json();",
                  "pm.test('reports both directions', () => {",
                  "  pm.expect(d.device).to.have.property('reachable');",
                  "  pm.expect(d.webhook).to.have.property('receiving');",
                  "});",
                  "// Surface the actual state in the runner output rather than only pass/fail.",
                  "console.log(`device reachable=${d.device.reachable} | webhook receiving=${d.webhook.receiving}`);",
                  "if (d.device.reachable && !d.webhook.receiving) {",
                  "  console.warn('Device is up but cannot reach this server — check the inbound firewall rule.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Device info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
