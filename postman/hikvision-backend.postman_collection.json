        {
          "name": "Delete person [DESTRUCTIVE]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/persons/{{employeeNo}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons",
                "{{employeeNo}}"
              ]
