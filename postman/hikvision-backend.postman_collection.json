      ]
    },
    {
      "name": "Fingerprints",
      "description": "[WRITES TO DEVICE]. Capture puts the terminal into scan mode and waits for a finger, so only run it when someone is standing at the device.\n\nNote: DELETE returned 'notSupport' on firmware V3.2.30 — removal may need to be done at the terminal instead.",
      "item": [
        {
          "name": "List a person's fingerprints",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/persons/{{employeeNo}}/fingerprints",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons",
                "{{employeeNo}}",
                "fingerprints"
              ]
            }
          }
        },
        {
          "name": "Enrol by scanning now [WRITES TO DEVICE]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fingerPrintID\": {{fingerPrintID}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/persons/{{employeeNo}}/fingerprint",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons",
                "{{employeeNo}}",
                "fingerprint"
              ]
            },
            "description": "Blocks until a finger is presented at the terminal (up to 60s), then applies the template and polls until the device confirms. fingerPrintID is the slot, 1-10, max 10 per person.\n\nEnrol two fingers per person — cuts and dry skin cause lockouts."
          }
        },
        {
          "name": "Enrol from existing template [WRITES TO DEVICE]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fingerPrintID\": {{fingerPrintID}},\n  \"fingerData\": \"PASTE_BASE64_TEMPLATE_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/persons/{{employeeNo}}/fingerprint",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons",
                "{{employeeNo}}",
                "fingerprint"
              ]
            },
            "description": "Applies a template captured earlier — use this to enrol the same finger onto several terminals without re-scanning."
          }
        },
        {
          "name": "Capture template only",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fingerNo\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/fingerprint/capture",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fingerprint",
                "capture"
              ]
            },
            "description": "Scans and returns {fingerNo, quality, fingerData} without assigning it to anyone. Quality is 1-100. The template is biometric data — do not log or store it casually."
          }
        },
        {
          "name": "Delete one fingerprint [DESTRUCTIVE]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/persons/{{employeeNo}}/fingerprints/{{fingerPrintID}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons",
                "{{employeeNo}}",
                "fingerprints",
                "{{fingerPrintID}}"
              ]
            }
          }
        },
        {
          "name": "Delete ALL fingerprints for person [DESTRUCTIVE]",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/persons/{{employeeNo}}/fingerprints",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "persons",
                "{{employeeNo}}",
                "fingerprints"
              ]
            },
            "description": "Removes every enrolled finger for this person. No undo."
          }
        }
      ]
    },
